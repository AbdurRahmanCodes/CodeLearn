# ─────────────────────────────────────────────────────────────
#  COM748 Research Platform — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
*.cover
nosetests.xml
coverage.xml

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# ── Flask / Werkzeug ─────────────────────────────────────────
instance/
.webassets-cache
flask_session/

# ── IDEs & Editors ───────────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ── OS Files ─────────────────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~

# ── Node (if any tooling is added later) ──────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Logs ────────────────────────────────────────────────────
*.log
logs/

# ── Exports & Local Data ─────────────────────────────────────
# Prevent accidentally committing exported research CSVs
*.csv
exports/

# ── Jupyter (if used for analysis) ──────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temp / misc ──────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
